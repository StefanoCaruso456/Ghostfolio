COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300&sslmode=prefer
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# PLAID — Broker Connection
# PLAID_CLIENT_ID=                   # Plaid Client ID from https://dashboard.plaid.com/developers/keys
# PLAID_SECRET=                      # Plaid Secret key (environment-specific)
# PLAID_ENV=sandbox                  # 'sandbox' (default), 'development', or 'production'

# AI AGENT — Market Data Provider
# MARKET_DATA_PROVIDER=yahoo          # 'yahoo' (default) or 'coingecko'
# MARKET_DATA_CACHE_ENABLED=true      # true (default) — in-memory TTL cache for market data
# API_KEY_COINGECKO_DEMO=             # CoinGecko demo API key (optional, reduces rate limits)
# API_KEY_COINGECKO_PRO=              # CoinGecko pro API key (optional, uses pro-api.coingecko.com)

# MCP SERVER — Model Context Protocol integration
# MCP_SERVER_URL=                     # URL of the ghostfolio-mcp-server (e.g. http://localhost:3001)
# MCP_API_KEY=                        # API key for authenticating with the MCP server
